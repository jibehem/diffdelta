{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Diff Delta",
  "scopeName": "source.diffdelta",
  "patterns": [
    { "match": "^\\+{3}.*$", "name": "markup.inserted.diffdelta.level3" },
    { "match": "^>{3}.*$", "name": "markup.inserted.diffdelta.level3" },
    { "match": "^/{3}.*$", "name": "markup.inserted.diffdelta.level3" },
    { "match": "^\\+{2}.*$", "name": "markup.inserted.diffdelta.level2" },
    { "match": "^>{2}.*$", "name": "markup.inserted.diffdelta.level2" },
    { "match": "^/{2}.*$", "name": "markup.inserted.diffdelta.level2" },
    { "match": "^\\+{1}.*$", "name": "markup.inserted.diffdelta.level1" },
    { "match": "^>{1}.*$", "name": "markup.inserted.diffdelta.level1" },
    { "match": "^/{1}.*$", "name": "markup.inserted.diffdelta.level1" },

    { "match": "^-{3}.*$", "name": "markup.deleted.diffdelta.level3" },
    { "match": "^<{3}.*$", "name": "markup.deleted.diffdelta.level3" },
    { "match": "^\\\\{3}.*$", "name": "markup.deleted.diffdelta.level3" },
    { "match": "^-{2}.*$", "name": "markup.deleted.diffdelta.level2" },
    { "match": "^<{2}.*$", "name": "markup.deleted.diffdelta.level2" },
    { "match": "^\\\\{2}.*$", "name": "markup.deleted.diffdelta.level2" },
    { "match": "^-{1}.*$", "name": "markup.deleted.diffdelta.level1" },
    { "match": "^<{1}.*$", "name": "markup.deleted.diffdelta.level1" },
    { "match": "^\\\\{1}.*$", "name": "markup.deleted.diffdelta.level1" },

    { "match": "^={3}.*$", "name": "markup.changed.diffdelta.level3" },
    { "match": "^@{3}.*$", "name": "markup.changed.diffdelta.level3" },
    { "match": "^={2}.*$", "name": "markup.changed.diffdelta.level2" },
    { "match": "^@{2}.*$", "name": "markup.changed.diffdelta.level2" },
    { "match": "^={1}.*$", "name": "markup.changed.diffdelta.level1" },
    { "match": "^@{1}.*$", "name": "markup.changed.diffdelta.level1" },

    { "match": "^\\*{3}.*$", "name": "markup.heading.diffdelta.level3" },
    { "match": "^#{3}.*$", "name": "markup.heading.diffdelta.level3" },
    { "match": "^\\*{2}.*$", "name": "markup.heading.diffdelta.level2" },
    { "match": "^#{2}.*$", "name": "markup.heading.diffdelta.level2" },
    { "match": "^\\*{1}.*$", "name": "markup.heading.diffdelta.level1" },
    { "match": "^#{1}.*$", "name": "markup.heading.diffdelta.level1" },

    { "match": "^!.*$", "name": "markup.bold.diffdelta" },

    { "match": "^\\?.*$", "name": "markup.italic.diffdelta" },

    { "match": "^\\s.*$", "name": "comment.diffdelta" }
  ]
}
