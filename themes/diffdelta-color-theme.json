{
  "name": "DiffDelta Theme",
 
  "colors": {
    "editor.background": "#0A0A0A",
    "editor.foreground": "#B3B3B3",

    "sideBar.background": "#0A0A0A",
    "sideBar.foreground": "#A8A8A8",

    "activityBar.background": "#0A0A0A",
    "activityBar.foreground": "#A8A8A8",
    "activityBar.inactiveForeground": "#5A5A5A",

    "panel.background": "#0A0A0A",
    "panel.border": "#1A1A1A",

    "statusBar.background": "#0A0A0A",
    "statusBar.foreground": "#9A9A9A",

    "titleBar.activeBackground": "#0A0A0A",
    "titleBar.inactiveBackground": "#0A0A0A",
    "titleBar.activeForeground": "#AFAFAF",
    "titleBar.inactiveForeground": "#6A6A6A",

    "editorLineNumber.foreground": "#3A3A3A",
    "editorLineNumber.activeForeground": "#6A6A6A",

    "editorCursor.foreground": "#8A8A8A",

    "editor.selectionBackground": "#1A1A1A",
    "editor.inactiveSelectionBackground": "#141414",

    "editorIndentGuide.background": "#1A1A1A",
    "editorIndentGuide.activeBackground": "#2A2A2A",

    "scrollbarSlider.background": "#1A1A1A88",
    "scrollbarSlider.hoverBackground": "#2A2A2A88",

    "list.hoverBackground": "#121212",
    "list.activeSelectionBackground": "#151515",
    "list.inactiveSelectionBackground": "#111111"
  },
  "tokenColors": [
    { "scope": "markup.inserted.diffdelta",         "settings": { "background": "#062617" } },
    { "scope": "markup.inserted.diffdelta.level1",  "settings": { "foreground": "#86EFAC", "background": "#062617" } },
    { "scope": "markup.inserted.diffdelta.level2",  "settings": { "foreground": "#4ADE80", "background": "#062617" } },
    { "scope": "markup.inserted.diffdelta.level3",  "settings": { "foreground": "#10B981", "background": "#062617" } },

    { "scope": "markup.deleted.diffdelta",          "settings": { "background": "#22080B" } },
    { "scope": "markup.deleted.diffdelta.level1",   "settings": { "foreground": "#FDA4AF", "background": "#22080B" } },
    { "scope": "markup.deleted.diffdelta.level2",   "settings": { "foreground": "#F87171", "background": "#22080B" } },
    { "scope": "markup.deleted.diffdelta.level3",   "settings": { "foreground": "#EF4444", "background": "#22080B" } },

    { "scope": "markup.changed.diffdelta",          "settings": { "background": "#081832" } },
    { "scope": "markup.changed.diffdelta.level1",   "settings": { "foreground": "#93C5FD", "background": "#081832" } },
    { "scope": "markup.changed.diffdelta.level2",   "settings": { "foreground": "#60A5FA", "background": "#081832" } },
    { "scope": "markup.changed.diffdelta.level3",   "settings": { "foreground": "#3B82F6", "background": "#081832" } },

    { "scope": "markup.heading.diffdelta",          "settings": { "background": "#052223" } },
    { "scope": "markup.heading.diffdelta.level1",   "settings": { "foreground": "#67E8F9", "background": "#052223" } },
    { "scope": "markup.heading.diffdelta.level2",   "settings": { "foreground": "#22D3EE", "background": "#052223" } },
    { "scope": "markup.heading.diffdelta.level3",   "settings": { "foreground": "#06B6D4", "background": "#052223" } },

    { "scope": "markup.bold.diffdelta",          "settings": { "foreground": "#F57F0A", "background": "#2A1A07" } },
    { "scope": "markup.italic.diffdelta",        "settings": { "foreground": "#EBEB07", "background": "#2A2405" } },
    { "scope": "comment.diffdelta",              "settings": { "foreground": "#9CA3AF" } },
    { "scope": "source.diffdelta",               "settings": { "foreground": "#DDDDDD" } }
  ]
}
